---
/**
 * Neo-Brutalist Link Button Component
 *
 * A link styled as a button, maintaining semantic HTML while providing button aesthetics.
 * Use for navigation actions that should look like buttons.
 *
 * @component
 * @example
 * <LinkButton href="/about">About Us</LinkButton>
 * <LinkButton href="https://example.com" target="_blank">External Link</LinkButton>
 */

export interface Props {
  /** URL to navigate to (required) */
  href: string;

  /** Visual style variant of the button */
  variant?: 'primary' | 'secondary' | 'success' | 'danger' | 'warning';

  /** Size of the button */
  size?: 'small' | 'medium' | 'large';

  /** Full width button */
  fullWidth?: boolean;

  /** Link target attribute */
  target?: '_self' | '_blank' | '_parent' | '_top';

  /** Relationship of the linked document */
  rel?: string;

  /** ARIA label for accessibility */
  ariaLabel?: string;

  /** Additional CSS classes */
  class?: string;
}

const {
  href,
  variant = 'primary',
  size = 'medium',
  fullWidth = false,
  target = '_self',
  rel,
  ariaLabel,
  class: className = '',
} = Astro.props;

// Validate required props
if (!href) {
  throw new Error('LinkButton requires href prop');
}

// Validate props defensively
const validVariants = ['primary', 'secondary', 'success', 'danger', 'warning'];
const validSizes = ['small', 'medium', 'large'];

const finalVariant = validVariants.includes(variant) ? variant : 'primary';
const finalSize = validSizes.includes(size) ? size : 'medium';

// Auto-set rel for external links
const isExternal = target === '_blank';
const finalRel = rel || (isExternal ? 'noopener noreferrer' : undefined);
---

<a
  href={href}
  target={target}
  rel={finalRel}
  aria-label={ariaLabel}
  class:list={[
    'neo-link-button',
    `neo-link-button--${finalVariant}`,
    `neo-link-button--${finalSize}`,
    { 'neo-link-button--full': fullWidth },
    className,
  ]}
>
  <slot />
</a>

<style>
  /* Base link button styles */
  .neo-link-button {
    --neo-black: var(--text-1);
    --neo-white: #ffffff;
    --neo-primary: var(--accent-1);
    --neo-secondary: var(--primary);
    --neo-success: #00ff88;
    --neo-danger: var(--accent-2);
    --neo-warning: var(--orange);

    --neo-border-width: 4px;
    --neo-shadow-offset: 6px;
    --neo-transition-speed: 0.15s;

    --neo-font-small: 0.875rem;
    --neo-font-medium: 1rem;
    --neo-font-large: 1.25rem;

    --neo-padding-small: 0.5rem 1rem;
    --neo-padding-medium: 0.75rem 1.5rem;
    --neo-padding-large: 1rem 2rem;

    /* Typography */
    font-family: 'Literata', 'Courier New', monospace;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-size: var(--neo-font-medium);

    /* Layout */
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: var(--neo-padding-medium);

    /* Visual */
    background: var(--neo-white);
    color: var(--neo-black);
    border: var(--neo-border-width) solid var(--neo-black);
    box-shadow: var(--neo-shadow-offset) var(--neo-shadow-offset) 0 var(--neo-black);

    /* Remove default link styling */
    text-decoration: none;

    /* Interaction */
    cursor: pointer;
    transition:
      transform var(--neo-transition-speed) ease,
      box-shadow var(--neo-transition-speed) ease;

    /* Prevent text selection */
    user-select: none;
    -webkit-user-select: none;

    /* Ensure proper positioning */
    position: relative;
  }

  /* Hover state */
  .neo-link-button:hover {
    transform: translate(3px, 3px);
    box-shadow: calc(var(--neo-shadow-offset) - 3px) calc(var(--neo-shadow-offset) - 3px) 0
      var(--neo-black);
  }

  /* Active/pressed state */
  .neo-link-button:active {
    transform: translate(var(--neo-shadow-offset), var(--neo-shadow-offset));
    box-shadow: 0 0 0 var(--neo-black);
  }

  /* Focus state for keyboard navigation */
  .neo-link-button:focus-visible {
    outline: 3px dashed var(--neo-black);
    outline-offset: 4px;
  }

  /* Variant: Primary */
  .neo-link-button--primary {
    background: var(--neo-primary);
    color: var(--bg-1);
  }

  /* Variant: Secondary */
  .neo-link-button--secondary {
    background: var(--neo-secondary);
    color: var(--bg-1);
  }

  /* Variant: Success */
  .neo-link-button--success {
    background: var(--neo-success);
    color: var(--neo-black);
  }

  /* Variant: Danger */
  .neo-link-button--danger {
    background: var(--neo-danger);
    color: var(--bg-1);
  }

  /* Variant: Warning */
  .neo-link-button--warning {
    background: var(--neo-warning);
    color: var(--bg-1);
  }

  /* Size: Small */
  .neo-link-button--small {
    font-size: var(--neo-font-small);
    padding: var(--neo-padding-small);
  }

  /* Size: Large */
  .neo-link-button--large {
    font-size: var(--neo-font-large);
    padding: var(--neo-padding-large);
  }

  /* Full width modifier */
  .neo-link-button--full {
    width: 100%;
  }

  /* High contrast mode support */
  @media (prefers-contrast: high) {
    .neo-link-button {
      border-width: 5px;
    }
  }

  /* Reduced motion support */
  @media (prefers-reduced-motion: reduce) {
    .neo-link-button {
      transition: none;
    }
  }

  /* Touch-friendly sizing */
  @media (pointer: coarse) {
    .neo-link-button {
      min-height: 44px;
      min-width: 44px;
    }
  }
</style>
