---
import { useEffect } from "astro/jsx-runtime";
---

<header class="nav-header">
  <div class="logo">KODANSHA</div>
  <button id="menu-button" aria-expanded="false" aria-controls="nav-menu">
    MENU
  </button>
  <nav id="nav-menu" hidden>
    <ul>
      <li><a href="#">Library</a></li>
      <li><a href="#">Release Calendar</a></li>
      <li><a href="#">New Releases</a></li>
      <li><a href="#">On Sale</a></li>
      <li><a href="#">News</a></li>
    </ul>
  </nav>
</header>

<style scoped>
.nav-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  position: relative;
}

.logo {
  font-weight: bold;
}

#menu-button {
  cursor: pointer;
  font-weight: bold;
}

#nav-menu {
  position: absolute;
  top: 3rem;
  right: 1rem;
  background: white;
  border: 1px solid #ccc;
  padding: 1em;
}

#nav-menu[hidden] {
  display: none;
}
</style>

<script>
  const menuButton = document.getElementById("menu-button");
  const navMenu = document.getElementById("nav-menu");

  menuButton.addEventListener("click", () => {
    const isOpen = menuButton.getAttribute("aria-expanded") === "true";
    menuButton.setAttribute("aria-expanded", String(!isOpen));
    navMenu.hidden = isOpen;
  });

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && menuButton.getAttribute("aria-expanded") === "true") {
      menuButton.setAttribute("aria-expanded", "false");
      navMenu.hidden = true;
    }
  });

  document.addEventListener("click", (e) => {
    if (!navMenu.contains(e.target) && e.target !== menuButton) {
      menuButton.setAttribute("aria-expanded", "false");
      navMenu.hidden = true;
    }
  });
</script>