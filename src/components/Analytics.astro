---
/**
 * Analytics Component
 * 
 * Handles Google Analytics and Umami tracking.
 * Optimized for standard MPAs and Astro's Client Router (View Transitions).
 * 
 * @component
 */

export interface Props {
  /** Google Analytics ID */
  googleAnalyticsId?: string;
  
  /** Umami website ID */
  umamiWebsiteId?: string;
  
  /** Umami script URL */
  umamiScriptUrl?: string;
}

const {
  googleAnalyticsId = import.meta.env.PUBLIC_GA_ID,
  umamiWebsiteId = import.meta.env.PUBLIC_UMAMI_ID,
  umamiScriptUrl = 'https://cloud.umami.is/script.js',
} = Astro.props;

const isProduction = import.meta.env.PROD;
---

{isProduction && googleAnalyticsId && (
  <!-- External Google Analytics Library -->
  <script 
    is:inline
    async 
    src={`https://www.googletagmanager.com/gtag/js?id=${googleAnalyticsId}`}
  />
  
  <!-- GA Initialization & Lifecycle Tracking -->
  <script 
    is:inline
    set:html={`
      window.dataLayer = window.dataLayer || [];
      window.gtag = function() {
        window.dataLayer.push(arguments);
      };

      // astro:page-load triggers on both initial load and view transitions
      document.addEventListener('astro:page-load', () => {
        window.gtag('js', new Date());
        window.gtag('config', '${googleAnalyticsId}');
      });
    `}
  />
)}

{isProduction && umamiWebsiteId && (
  <!-- Umami Analytics (data-astro-rerun ensures tracking on View Transitions) -->
  <script 
    is:inline
    defer 
    src={umamiScriptUrl}
    data-website-id={umamiWebsiteId}
    data-astro-rerun
  />
)}

{!isProduction && (
  <script is:inline>
    console.log('📊 Analytics disabled in development mode');
  </script>
)}
