---
import type { CollectionEntry } from 'astro:content';
import { render } from 'astro:content';

interface Props {
  updates: CollectionEntry<'updates'>[];
}

const { updates } = Astro.props;

const processedUpdates = await Promise.all(
  updates.map(async (update) => {
    const { Content } = await render(update);
    
    const isValidDate = update.data.date instanceof Date && !isNaN(update.data.date.getTime());
    const isoString = isValidDate ? update.data.date.toISOString() : new Date().toISOString();
    const formatted = isValidDate ? formatDate(update.data.date) : 'Unknown Date';

    return {
      ...update,
      Content,
      isoString,
      formatted,
    };
  })
);

function formatDate(date: Date): string {
  return date.toLocaleDateString('en-US', {
    month: 'short',
    day: 'numeric',
    year: 'numeric',
  });
}
---

<div class="info-box">
  {processedUpdates.length === 0 && <p class="empty">no updates yet.</p>}
  
  {
    processedUpdates.map(({ Content, isoString, formatted }) => (
      <div class="update-item">
        <time class="update-date" datetime={isoString}>
          {formatted}
        </time>
        {/* Use a global utility class defined in your main global.css layout */}
        <div class="update-content global-prose-wrapper">
          <Content />
        </div>
      </div>
    ))
  }
</div>

<style>
  /* All styles here are now strictly scoped to this component only */
  .info-box {
    width: 100%;
    max-width: 100%;
    box-sizing: border-box;
  }
  
  .update-item {
    padding: 12px 0;
    border-bottom: 1px solid var(--border-muted);
    width: 100%;
    max-width: 100%;
    box-sizing: border-box;
  }
  
  .update-item:last-child {
    border-bottom: none;
  }
  
  .update-date {
    display: block;
    font-size: var(--font-xs);
    margin-bottom: 4px;
    font-family: var(--font-mono);
  }
  
  .empty {
    font-size: var(--font-xs);
    opacity: 0.5;
    font-family: var(--font-mono);
  }
</style>
