---
interface Props {
  title?: string;
}
const { title = "NEWS" } = Astro.props;
---

<div class="relative max-w-md mx-auto p-1 bg-gradient-to-b from-[#4a6ba3] to-[#1a2b4a] rounded-sm shadow-2xl font-serif">
  <div class="border-[1.5px] border-[#5d87c9] p-1.5">
    
    <div class="relative bg-[#0a1221] min-h-[600px] border border-[#2a457a] overflow-hidden">
      
      <div class="absolute inset-0 opacity-20 pointer-events-none" 
           style="background-image: radial-gradient(#4a6ba3 1px, transparent 1px); background-size: 20px 20px; background-position: 10px 10px; transform: rotate(45deg) scale(2);">
      </div>

      <div class="relative z-10 flex items-center justify-center py-4 px-6">
        <div class="flex-grow h-[1px] bg-gradient-to-r from-transparent via-[#5d87c9] to-[#5d87c9]"></div>
        
        <div class="flex items-center px-4 border border-[#5d87c9] bg-[#0a1221] py-1 shadow-[0_0_10px_rgba(93,135,201,0.3)]">
          <span class="text-[#d4af37] text-sm mr-3">❈</span>
          <h2 class="text-[#e2e8f0] text-xl tracking-[0.2em] font-light">{title}</h2>
          <span class="text-[#d4af37] text-sm ml-3">❈</span>
        </div>
        
        <div class="flex-grow h-[1px] bg-gradient-to-l from-transparent via-[#5d87c9] to-[#5d87c9]"></div>
      </div>

      <div class="relative z-10 px-6 py-2 space-y-1">
        <slot />
      </div>

      <div class="absolute bottom-4 right-6 z-10">
        <button class="text-[#a0aec0] text-sm hover:text-white transition-colors">
          もっと見る
        </button>
      </div>
    </div>
  </div>
</div>