---
/**
 * Neo-Brutalist Icon Button Component
 * 
 * Square button designed for icons with consistent aspect ratio.
 * Follows neo-brutalism design with thick borders and offset shadows.
 * 
 * @component
 * @example
 * <IconButton ariaLabel="Close dialog">
 *   <svg>...</svg>
 * </IconButton>
 */

export interface Props {
  /** Visual style variant of the button */
  variant?: 'primary' | 'secondary' | 'success' | 'danger' | 'warning';
  
  /** Size of the button */
  size?: 'small' | 'medium' | 'large';
  
  /** Disabled state */
  disabled?: boolean;
  
  /** Button type attribute */
  type?: 'button' | 'submit' | 'reset';
  
  /** REQUIRED: ARIA label for accessibility (critical for icon-only buttons) */
  ariaLabel: string;
  
  /** Additional CSS classes */
  class?: string;
  
  /** Click handler (client-side only) */
  onClick?: string;
}

const {
  variant = 'primary',
  size = 'medium',
  disabled = false,
  type = 'button',
  ariaLabel,
  class: className = '',
  onClick,
} = Astro.props;

// Validate required props
if (!ariaLabel) {
  throw new Error('IconButton requires ariaLabel prop for accessibility');
}

// Validate props defensively
const validVariants = ['primary', 'secondary', 'success', 'danger', 'warning'];
const validSizes = ['small', 'medium', 'large'];

const finalVariant = validVariants.includes(variant) ? variant : 'primary';
const finalSize = validSizes.includes(size) ? size : 'medium';
---

<button
  type={type}
  disabled={disabled}
  aria-label={ariaLabel}
  class:list={[
    'neo-icon-button',
    `neo-icon-button--${finalVariant}`,
    `neo-icon-button--${finalSize}`,
    { 'neo-icon-button--disabled': disabled },
    className
  ]}
  onclick={onClick}
>
  <slot />
</button>

<style>
  /* Design tokens */
  :root {
    --neo-black: #000000;
    --neo-white: #ffffff;
    --neo-primary: #00ff00;
    --neo-secondary: #00ffff;
    --neo-success: #00ff88;
    --neo-danger: #ff0055;
    --neo-warning: #ffaa00;
    
    --neo-border-width: 4px;
    --neo-shadow-offset: 6px;
    --neo-transition-speed: 0.15s;
    
    --neo-icon-small: 2rem;
    --neo-icon-medium: 2.75rem;
    --neo-icon-large: 3.5rem;
  }

  /* Base icon button styles */
  .neo-icon-button {
    /* Layout - square aspect ratio */
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: var(--neo-icon-medium);
    height: var(--neo-icon-medium);
    padding: 0;
    
    /* Visual */
    background: var(--neo-white);
    color: var(--neo-black);
    border: var(--neo-border-width) solid var(--neo-black);
    box-shadow: 
      var(--neo-shadow-offset) var(--neo-shadow-offset) 0 var(--neo-black);
    
    /* Interaction */
    cursor: pointer;
    transition: 
      transform var(--neo-transition-speed) ease,
      box-shadow var(--neo-transition-speed) ease;
    
    /* Prevent text selection */
    user-select: none;
    -webkit-user-select: none;
    
    /* Ensure proper positioning */
    position: relative;
    
    /* Reset unwanted styles */
    appearance: none;
    -webkit-appearance: none;
  }

  /* Ensure icons fill the button properly */
  .neo-icon-button :global(svg),
  .neo-icon-button :global(img) {
    width: 60%;
    height: 60%;
    display: block;
  }

  /* Hover state */
  .neo-icon-button:hover:not(.neo-icon-button--disabled) {
    transform: translate(3px, 3px);
    box-shadow: 
      calc(var(--neo-shadow-offset) - 3px) calc(var(--neo-shadow-offset) - 3px) 0 var(--neo-black);
  }

  /* Active/pressed state */
  .neo-icon-button:active:not(.neo-icon-button--disabled) {
    transform: translate(var(--neo-shadow-offset), var(--neo-shadow-offset));
    box-shadow: 0 0 0 var(--neo-black);
  }

  /* Focus state for keyboard navigation */
  .neo-icon-button:focus-visible {
    outline: 3px dashed var(--neo-black);
    outline-offset: 4px;
  }

  /* Variant: Primary */
  .neo-icon-button--primary {
    background: var(--neo-primary);
    color: var(--neo-black);
  }

  /* Variant: Secondary */
  .neo-icon-button--secondary {
    background: var(--neo-secondary);
    color: var(--neo-black);
  }

  /* Variant: Success */
  .neo-icon-button--success {
    background: var(--neo-success);
    color: var(--neo-black);
  }

  /* Variant: Danger */
  .neo-icon-button--danger {
    background: var(--neo-danger);
    color: var(--neo-white);
  }

  /* Variant: Warning */
  .neo-icon-button--warning {
    background: var(--neo-warning);
    color: var(--neo-black);
  }

  /* Size: Small */
  .neo-icon-button--small {
    width: var(--neo-icon-small);
    height: var(--neo-icon-small);
  }

  /* Size: Large */
  .neo-icon-button--large {
    width: var(--neo-icon-large);
    height: var(--neo-icon-large);
  }

  /* Disabled state */
  .neo-icon-button--disabled {
    opacity: 0.5;
    cursor: not-allowed;
    pointer-events: none;
  }

  /* Ensure consistent rendering across browsers */
  .neo-icon-button::-moz-focus-inner {
    border: 0;
    padding: 0;
  }

  /* High contrast mode support */
  @media (prefers-contrast: high) {
    .neo-icon-button {
      border-width: 5px;
    }
  }

  /* Reduced motion support */
  @media (prefers-reduced-motion: reduce) {
    .neo-icon-button {
      transition: none;
    }
  }

  /* Touch-friendly sizing */
  @media (pointer: coarse) {
    .neo-icon-button--small {
      width: 44px;
      height: 44px;
    }
  }
</style>
