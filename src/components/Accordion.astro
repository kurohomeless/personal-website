---
/**
 * Neo-Brutalist Accordion Component (PROPER IMPLEMENTATION)
 *
 * Fully accessible accordion using native <details> and <summary> elements.
 * Supports exclusive behavior (only one open) and proper semantic grouping.
 *
 * KEY FEATURES:
 * - Uses native HTML (no ARIA needed)
 * - Proper semantic grouping with heading
 * - Exclusive accordion with name attribute
 * - Keyboard accessible by default
 * - Screen reader friendly
 *
 * @component
 * @example
 * <Accordion title="FAQ">
 *   <AccordionItem summary="Question 1">Answer 1</AccordionItem>
 *   <AccordionItem summary="Question 2">Answer 2</AccordionItem>
 * </Accordion>
 */

export interface Props {
  /** Title for the accordion group */
  title?: string;

  /** Heading level for the title (h2, h3, etc.) */
  headingLevel?: 2 | 3 | 4 | 5 | 6;

  /** Unique name for exclusive accordion behavior (only one open at a time) */
  name?: string;

  /** Allow multiple items to be open (disables exclusive behavior) */
  allowMultiple?: boolean;

  /** Additional CSS classes */
  class?: string;
}

const {
  title,
  headingLevel = 2,
  name = 'accordion',
  allowMultiple = false,
  class: className = '',
} = Astro.props;

const HeadingTag = `h${headingLevel}` as const;
---

<!-- Proper semantic grouping -->
<section
  class:list={['neo-accordion', className]}
  aria-labelledby={title ? 'accordion-title' : undefined}
>
  {
    title && (
      <HeadingTag id="accordion-title" class="neo-accordion__title">
        {title}
      </HeadingTag>
    )
  }

  <div class="neo-accordion__items">
    <slot />
  </div>
</section>

<style>
  /* Design tokens */

  /* Accordion container */
  .neo-accordion {
    --neo-black: var(--text-1);
    --neo-white: #ffffff;
    --neo-gray: #f5f5f5;
    --neo-border-width: 4px;

    margin: 2rem 0;
  }

  /* Accordion title */
  .neo-accordion__title {
    font-family: 'Literata', monospace;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 1.5rem;
    color: var(--neo-black);
  }

  /* Items container */
  .neo-accordion__items {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
</style>
