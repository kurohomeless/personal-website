---
// NewsCard.astro
interface Props {
  title: string;
  date?: string;
  time?: string;
  type?: 'announcement' | 'news' | 'event';
}

const { title, date, time, type = 'news' } = Astro.props;
---

<div class="news-card">
  <div class="news-header">
    <span class="ornament">❋</span>
    <h2>NEWS</h2>
    <span class="ornament">❋</span>
  </div>

  <div class="news-content">
    <div class="news-item">
      <h3>{title}</h3>
      {
        (date || time) && (
          <p class="news-meta">
            【ニュース】{date} {time}
          </p>
        )
      }
    </div>
  </div>

  <button class="view-more">もっと見る</button>

  <div class="social-section">
    <p class="twitter-link">Tweets by overlord_ch</p>
  </div>
</div>

<style>
  .news-card {
    background: linear-gradient(180deg, #1a1f3a 0%, #0d1124 100%);
    border: 2px solid #4a6b8a;
    border-radius: 4px;
    padding: 0;
    color: #e8e8e8;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    max-width: 800px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.6);
    position: relative;
  }

  .news-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background:
      repeating-linear-gradient(
        90deg,
        transparent,
        transparent 20px,
        rgba(74, 107, 138, 0.1) 20px,
        rgba(74, 107, 138, 0.1) 40px
      ),
      repeating-linear-gradient(
        0deg,
        transparent,
        transparent 20px,
        rgba(74, 107, 138, 0.1) 20px,
        rgba(74, 107, 138, 0.1) 40px
      );
    pointer-events: none;
    border-radius: 4px;
  }

  .news-header {
    background: linear-gradient(180deg, #2a3555 0%, #1f2844 100%);
    border: 2px solid #4a6b8a;
    border-radius: 4px;
    margin: 20px 40px;
    padding: 12px 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 20px;
    position: relative;
    z-index: 1;
  }

  .news-header h2 {
    color: #d4af76;
    font-size: 28px;
    font-weight: 400;
    letter-spacing: 8px;
    margin: 0;
    text-shadow: 0 2px 4px rgba(0, 0, 0, 0.5);
  }

  .ornament {
    color: #d4af76;
    font-size: 20px;
  }

  .news-content {
    padding: 30px 50px;
    position: relative;
    z-index: 1;
  }

  .news-item {
    border-bottom: 1px solid rgba(74, 107, 138, 0.3);
    padding: 20px 0;
  }

  .news-item:last-child {
    border-bottom: none;
  }

  .news-item h3 {
    color: #e8e8e8;
    font-size: 18px;
    font-weight: 400;
    line-height: 1.6;
    margin: 0 0 10px 0;
  }

  .news-meta {
    color: #a8b8c8;
    font-size: 14px;
    margin: 0;
  }

  .view-more {
    background: transparent;
    border: none;
    color: #e8e8e8;
    font-size: 16px;
    padding: 20px;
    cursor: pointer;
    text-align: right;
    width: 100%;
    position: relative;
    z-index: 1;
    transition: color 0.3s ease;
  }

  .view-more:hover {
    color: #d4af76;
  }

  .social-section {
    background: rgba(0, 0, 0, 0.3);
    padding: 40px;
    position: relative;
    z-index: 1;
    border-top: 1px solid rgba(74, 107, 138, 0.3);
  }

  .twitter-link {
    color: #7a8a9a;
    font-size: 16px;
    margin: 0;
  }
</style>
