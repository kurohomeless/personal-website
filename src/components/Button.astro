---
/**
 * Neo-Brutalist Button Component
 *
 * A bold, unapologetic button following neo-brutalism design principles.
 * Features thick borders, offset shadows, and aggressive typography.
 *
 * @component
 * @example
 * <Button>Click Me</Button>
 * <Button variant="secondary" size="large">Large Button</Button>
 * <Button variant="danger" disabled>Disabled</Button>
 */

export interface Props {
  /** Visual style variant of the button */
  variant?: 'primary' | 'secondary' | 'success' | 'danger' | 'warning';

  /** Size of the button */
  size?: 'small' | 'medium' | 'large';

  /** Disabled state */
  disabled?: boolean;

  /** Full width button */
  fullWidth?: boolean;

  /** Button type attribute */
  type?: 'button' | 'submit' | 'reset';

  /** ARIA label for accessibility */
  ariaLabel?: string;

  /** Additional CSS classes */
  class?: string;

  /** Click handler (client-side only) */
  onClick?: string;
}

const {
  variant = 'primary',
  size = 'medium',
  disabled = false,
  fullWidth = false,
  type = 'button',
  ariaLabel,
  class: className = '',
  onClick,
} = Astro.props;

// Validate props defensively
const validVariants = ['primary', 'secondary', 'success', 'danger', 'warning'];
const validSizes = ['small', 'medium', 'large'];

const finalVariant = validVariants.includes(variant) ? variant : 'primary';
const finalSize = validSizes.includes(size) ? size : 'medium';
---

<button
  type={type}
  disabled={disabled}
  aria-label={ariaLabel}
  class:list={[
    'neo-button',
    `neo-button--${finalVariant}`,
    `neo-button--${finalSize}`,
    { 'neo-button--full': fullWidth },
    { 'neo-button--disabled': disabled },
    className,
  ]}
  onclick={onClick}
>
  <slot />
</button>

<style>
  /* Design tokens */
  :root {
    --neo-black: #000000;
    --neo-white: #ffffff;
    --neo-primary: #00ff00;
    --neo-secondary: #00ffff;
    --neo-success: #00ff88;
    --neo-danger: #ff0055;
    --neo-warning: #ffaa00;

    --neo-border-width: 4px;
    --neo-shadow-offset: 6px;
    --neo-transition-speed: 0.15s;

    --neo-font-small: 0.875rem;
    --neo-font-medium: 1rem;
    --neo-font-large: 1.25rem;

    --neo-padding-small: 0.5rem 1rem;
    --neo-padding-medium: 0.75rem 1.5rem;
    --neo-padding-large: 1rem 2rem;
  }

  /* Base button styles */
  .neo-button {
    /* Typography */
    font-family: 'Space Mono', 'Courier New', monospace;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-size: var(--neo-font-medium);

    /* Layout */
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: var(--neo-padding-medium);

    /* Visual */
    background: var(--neo-white);
    color: var(--neo-black);
    border: var(--neo-border-width) solid var(--neo-black);
    box-shadow: var(--neo-shadow-offset) var(--neo-shadow-offset) 0 var(--neo-black);

    /* Interaction */
    cursor: pointer;
    transition:
      transform var(--neo-transition-speed) ease,
      box-shadow var(--neo-transition-speed) ease;

    /* Prevent text selection */
    user-select: none;
    -webkit-user-select: none;

    /* Ensure proper positioning */
    position: relative;

    /* Reset unwanted styles */
    text-decoration: none;
    appearance: none;
    -webkit-appearance: none;
  }

  /* Hover state */
  .neo-button:hover:not(.neo-button--disabled) {
    transform: translate(3px, 3px);
    box-shadow: calc(var(--neo-shadow-offset) - 3px) calc(var(--neo-shadow-offset) - 3px) 0
      var(--neo-black);
  }

  /* Active/pressed state */
  .neo-button:active:not(.neo-button--disabled) {
    transform: translate(var(--neo-shadow-offset), var(--neo-shadow-offset));
    box-shadow: 0 0 0 var(--neo-black);
  }

  /* Focus state for keyboard navigation */
  .neo-button:focus-visible {
    outline: 3px dashed var(--neo-black);
    outline-offset: 4px;
  }

  /* Variant: Primary */
  .neo-button--primary {
    background: var(--neo-primary);
    color: var(--neo-black);
  }

  /* Variant: Secondary */
  .neo-button--secondary {
    background: var(--neo-secondary);
    color: var(--neo-black);
  }

  /* Variant: Success */
  .neo-button--success {
    background: var(--neo-success);
    color: var(--neo-black);
  }

  /* Variant: Danger */
  .neo-button--danger {
    background: var(--neo-danger);
    color: var(--neo-white);
  }

  /* Variant: Warning */
  .neo-button--warning {
    background: var(--neo-warning);
    color: var(--neo-black);
  }

  /* Size: Small */
  .neo-button--small {
    font-size: var(--neo-font-small);
    padding: var(--neo-padding-small);
  }

  /* Size: Large */
  .neo-button--large {
    font-size: var(--neo-font-large);
    padding: var(--neo-padding-large);
  }

  /* Full width modifier */
  .neo-button--full {
    width: 100%;
  }

  /* Disabled state */
  .neo-button--disabled {
    opacity: 0.5;
    cursor: not-allowed;
    pointer-events: none;
  }

  /* Ensure consistent rendering across browsers */
  .neo-button::-moz-focus-inner {
    border: 0;
    padding: 0;
  }

  /* High contrast mode support */
  @media (prefers-contrast: high) {
    .neo-button {
      border-width: 5px;
    }
  }

  /* Reduced motion support */
  @media (prefers-reduced-motion: reduce) {
    .neo-button {
      transition: none;
    }
  }

  /* Touch-friendly sizing */
  @media (pointer: coarse) {
    .neo-button {
      min-height: 44px;
      min-width: 44px;
    }
  }
</style>
