---
import Footer from '../components/Footer.astro';
import Foot from '../components/Foot.astro';

const {
  title = 'need $10 before Jan 27 - cashier making lewd AI cards',
  description = 'Cashier working 12+ hour shifts trying to make extra money with AI character cards. Need $10 before Jan 27. Free downloads, donations welcome. Commission work available.',
} = Astro.props;
import { ClientRouter } from 'astro:transitions';

import '../styles/global.css';
---

<!doctype html>
<html lang="en">
  <head>
    <ClientRouter />
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />

    <title>{title}</title>
    <link
      rel="preload"
      href="/fonts/AtkinsonHyperlegibleNext-Regular.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
  </head>

  <body>

    <main class="container">
      <slot />
    </main>

    <script
      defer
      src="https://cloud.umami.is/script.js"
      data-website-id="5fd83555-966a-4759-bd41-c23c6631b870"></script>
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-8695BPSRGY"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag('js', new Date());

      gtag('config', 'G-8695BPSRGY');
    </script>
  </body>
</html>
